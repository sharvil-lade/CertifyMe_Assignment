# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=production

# Database Configuration (Supabase or PostgreSQL)
# For production, use your PostgreSQL URL
# Format: postgresql+psycopg://user:password@host:port/database
SUPABASE_DB_URL=postgresql+psycopg://user:password@localhost:5432/database_name

# For local development, you can omit SUPABASE_DB_URL to use SQLite
# Uncomment the line below for local SQLite development:
# SUPABASE_DB_URL=sqlite:///admin_portal.db
